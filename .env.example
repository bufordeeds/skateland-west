# PostgreSQL Database connection string (required)
POSTGRES_URL=postgresql://user:password@localhost:5432/skateland-west

# Used to encrypt JWT tokens (required)
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash (required)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Vercel Blob storage token (required for production/Vercel deployment)
BLOB_READ_WRITE_TOKEN=vercel_blob_token_here

# Auto-migrate database on start (set to "true" for Vercel deployment)
DATABASE_MIGRATE_ON_START=false

# Secret used to authenticate cron jobs (optional)
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests (optional)
PREVIEW_SECRET=YOUR_SECRET_HERE

# ---- Newsletter signup form (required for /api/newsletter-subscribe) ----
#
# Spam protection: Cloudflare Turnstile.
#   Site key is exposed to the client (must be NEXT_PUBLIC_*).
#   Secret key stays on the server.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA_REPLACE_ME
TURNSTILE_SECRET_KEY=0x4AAAAAAA_REPLACE_ME
#
# Subscriber sink: Google Sheet (placeholder; see src/lib/subscriberSink.ts).
#   GOOGLE_SERVICE_ACCOUNT_JSON: full service-account JSON, base64-encoded.
#     (Raw JSON also accepted — the loader detects which.)
#   SUBSCRIBERS_SHEET_ID: spreadsheet ID from the Google Sheet URL.
#   SUBSCRIBERS_SHEET_TAB: tab name to append to (defaults to "Subscribers").
#   The sheet must be shared with the service account's client_email as Editor.
GOOGLE_SERVICE_ACCOUNT_JSON=base64-encoded-service-account-json-here
SUBSCRIBERS_SHEET_ID=replace-with-spreadsheet-id
SUBSCRIBERS_SHEET_TAB=Subscribers
#
# To swap providers later (Mailchimp, Listmonk, etc.):
#   1. Replace the body of appendSubscriber() in src/lib/subscriberSink.ts.
#   2. Replace GOOGLE_SERVICE_ACCOUNT_JSON / SUBSCRIBERS_SHEET_* with the
#      new provider's env vars.
#   No route or component changes required.
